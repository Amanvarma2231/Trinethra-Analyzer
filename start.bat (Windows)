@echo off
echo 🚀 Starting Trinethra Supervisor Feedback Analyzer
echo ==================================================

:: Check if Ollama is running
curl -s http://localhost:11434/api/tags >nul 2>&1
if errorlevel 1 (
    echo ❌ Ollama is not running. Please start Ollama first.
    echo    Run: ollama serve
    pause
    exit /b 1
)

echo ✅ Ollama is running

:: Start backend
echo 📡 Starting backend server...
cd backend
start "Trinethra Backend" cmd /k "pip install -q -r requirements.txt && python app.py"
timeout /t 3 /nobreak >nul

:: Start frontend
echo 🌐 Starting frontend server...
cd ../frontend
start "Trinethra Frontend" cmd /k "python -m http.server 5500"

echo.
echo ✨ Trinethra is ready!
echo    Frontend: http://localhost:5500
echo    Backend:  http://localhost:8005
echo    API Docs: http://localhost:8005/docs
echo.
echo Close the command windows to stop services
pause
